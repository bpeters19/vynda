# ── Axxess API ──────────────────────────────────────────────
AXXESS_BASE_URL=https://homehealth.axxess.com
AXXESS_AUTH_URL=https://identity.axxess.com/connect/token
AXXESS_CLIENT_ID=your_client_id_here
AXXESS_CLIENT_SECRET=your_client_secret_here
AXXESS_ACCOUNT_ID=your_agency_guid_here
AXXESS_TIME_ZONE=America/Chicago

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── Anthropic (Claude) ───────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── OpenAI (Whisper transcription) ──────────────────────────
OPENAI_API_KEY=your_openai_key_here

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=generate_a_strong_random_secret_here
